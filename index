      </div>
      <div class="dish-body">
        <div class="dish-cat">${d.cat}</div>
        <h3 class="dish-name">${hl(d.name, q)}</h3>
        <p class="dish-desc">${hl(d.tagline, q)}</p>
        <div class="dish-meta">
          <div class="dish-stars">${starsHtml(d.id, true)}</div>
