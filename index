/* ============================================================
   NAVBAR
   ============================================================ */
function initNavbar() {
  const nav = $('navbar'), ham = $('hamburger'), mob = $('mobile-nav');
  if(!nav) return;
  window.addEventListener('scroll', ()=>{
    nav.classList.toggle('scrolled', window.scrollY > 60);
    const btt = $('back-top');
    if(btt) btt.classList.toggle('show', window.scrollY > 500);
  }, { passive: true });
  if(ham && mob) {
    ham.addEventListener('click', ()=>{
      STATE.navOpen = !STATE.navOpen;
      ham.classList.toggle('open', STATE.navOpen);
      mob.classList.toggle('open', STATE.navOpen);
      document.body.style.overflow = STATE.navOpen ? 'hidden' : '';
    });
  }
  $$('.nav-link').forEach(link=>{
    link.addEventListener('click', e=>{
      const href = link.getAttribute('href') || '';
      if(!href.startsWith('#')) return;
      e.preventDefault();
      navScrollTo(href);
      if(STATE.navOpen) {
        STATE.navOpen = false;
        if(ham) ham.classList.remove('open');
        if(mob) mob.classList.remove('open');
        document.body.style.overflow = '';
      }
    });
  });
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(en=>{
      if(en.isIntersecting) {
        $$('.nav-link').forEach(l => l.classList.toggle('active', l.getAttribute('href') === '#' + en.target.id));
      }
    });
  }, { threshold: 0.3 });
  $$('section[id]').forEach(s => obs.observe(s));
}

/* ============================================================
   SCROLL REVEAL (AOS)
   ============================================================ */
function initReveal() {
  if(!('IntersectionObserver' in window)) {
    $$('[data-aos]').forEach(el => el.classList.add('aos-in'));
    return;
  }
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(en=>{
      if(!en.isIntersecting) return;
      const d = parseInt(en.target.dataset.aosDelay || 0);
      setTimeout(()=> en.target.classList.add('aos-in'), d);
      obs.unobserve(en.target);
    });
  }, { threshold: 0.1, rootMargin: '0px 0px -50px 0px' });
  $$('[data-aos]').forEach(el => obs.observe(el));
}

/* ============================================================
   RENDER — DISHES
   ============================================================ */
function starsHtml(dishId, interactive) {
  const r = STATE.ratings[dishId] || (DISHES.find(d => d.id === dishId) || {}).stars || 0;
  return Array.from({ length: 5 }, (_, i) => {
    const n = i + 1, on = n <= r ? 'on' : '';
    if(interactive) return `<button class="star-btn ${on}" data-dish="${dishId}" data-star="${n}" aria-label="${n} sao">★</button>`;
    return `<span class="star-btn ${on}">★</span>`;
  }).join('');
}

function hl(text, q) {
  if(!q || !text) return text || '';
  try {
    return String(text).replace(new RegExp('(' + q.replace(/[.*+?^${}()|[\]\\]/g,'\\$&') + ')','gi'), '<mark class="hl">$1</mark>');
  } catch(e) { return text; }
}

function renderSkeletons(n) {
