}

function renderDishes() {
  const grid = $('dishes-grid'), countEl = $('result-count');
  if(!grid) return;
  const q = (STATE.query || '').toLowerCase().trim();
  const f = STATE.filter || 'all';
  const list = DISHES.filter(d =>
    (f === 'all' || d.region === f) &&
    (!q || d.name.toLowerCase().includes(q) || d.regionLabel.toLowerCase().includes(q) || d.cat.toLowerCase().includes(q))
  );
  if(countEl) countEl.textContent = list.length + ' món ăn';
  if(!list.length) {
    grid.innerHTML = '<div class="no-results"><div class="no-results-icon">🔍</div><h3>Không tìm thấy món ăn</h3><p>Thử tìm với từ khoá khác hoặc đặt lại bộ lọc.</p></div>';
