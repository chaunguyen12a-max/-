<!DOCTYPE html>
<html lang="vi" data-theme="light">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<meta name="description" content="Khám phá ẩm thực Việt Nam qua 3 vùng miền — công thức, hình ảnh và video nấu ăn chuẩn vị."/>
<title>Ẩm Thực Việt Nam — Hương Vị Quê Hương</title>
<link rel="preconnect" href="https://fonts.googleapis.com"/>
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin/>
<link href="https://fonts.googleapis.com/css2?family=Be+Vietnam+Pro:wght@300;400;500;600;700;800&family=Playfair+Display:ital,wght@0,600;0,700;0,800;0,900;1,600;1,700&display=swap" rel="stylesheet"/>
<!-- FAVICON: Thay đổi emoji 🍜 thành emoji hoặc URL ảnh icon khác nếu muốn -->
<link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>🍜</text></svg>"/>
<style>
/* ============================================================
   CSS VARIABLES
   ============================================================ */
:root {
  --red-900:#7B1919; --red-700:#C0392B; --red-500:#E74C3C; --red-100:#FDECEA;
  --gold-700:#B7860D; --gold-500:#D4A017; --gold-300:#F1C40F; --gold-100:#FEF9E7;
  --amber-500:#E67E22; --amber-300:#F39C12;
  --brown-900:#2C1A0E; --brown-700:#5C3317; --brown-500:#8B5E3C; --brown-100:#F5EDE4;
  --ink:#1A0A00; --ink-50:#6B4230; --ink-30:#9E7A60;
  --border:rgba(139,94,60,.15);
  --bg:#FFFBF4; --bg-card:#FFFFFF; --bg-overlay:rgba(255,251,244,.95);
  --text-head:#1A0A00; --text-body:#3D2010; --text-muted:#6B4230;
  --nav-bg:rgba(255,251,244,.94);
  --sh-xs:0 1px 4px rgba(139,94,60,.08);
  --sh-sm:0 2px 12px rgba(139,0,0,.10);
  --sh-md:0 8px 32px rgba(139,0,0,.14);
  --sh-lg:0 20px 60px rgba(139,0,0,.18);
  --sh-xl:0 32px 80px rgba(139,0,0,.22);
  --grad-hero:linear-gradient(135deg,#8B0000 0%,#C0392B 40%,#E67E22 75%,#F39C12 100%);
  --grad-gold:linear-gradient(135deg,#D4A017,#F1C40F,#D4A017);
  --grad-warm:linear-gradient(135deg,#C0392B,#E67E22);
  --nav-h:74px; --max-w:1300px;
  --r-sm:8px; --r-md:16px; --r-lg:24px; --r-xl:36px; --r-2xl:48px;
  --ease:cubic-bezier(.4,0,.2,1);
  --spring:cubic-bezier(.34,1.56,.64,1);
}
[data-theme="dark"] {
  --bg:#0F0600; --bg-card:#1C0C04; --bg-overlay:rgba(15,6,0,.96);
  --text-head:#FFF3E0; --text-body:#D4A882; --text-muted:#9E7A60;
  --border:rgba(212,160,23,.14); --nav-bg:rgba(15,6,0,.94);
  --sh-sm:0 2px 12px rgba(0,0,0,.35); --sh-md:0 8px 32px rgba(0,0,0,.45);
  --sh-lg:0 20px 60px rgba(0,0,0,.55); --sh-xl:0 32px 80px rgba(0,0,0,.65);
  --red-100:#200A02; --gold-100:#1A1200; --brown-100:#180900;
}

/* ============================================================
   RESET
   ============================================================ */
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth;font-size:16px}
body{font-family:'Be Vietnam Pro',sans-serif;background:var(--bg);color:var(--text-body);line-height:1.65;overflow-x:hidden;transition:background .4s,color .4s}
img{display:block;max-width:100%;object-fit:cover}
a{color:inherit;text-decoration:none}
ul{list-style:none}
button{cursor:pointer;font-family:inherit;border:none;outline:none;background:none}
input,textarea,select{font-family:inherit}
::-webkit-scrollbar{width:7px}
::-webkit-scrollbar-track{background:var(--brown-100)}
::-webkit-scrollbar-thumb{background:var(--grad-warm);border-radius:4px}

/* ============================================================
   UTILITIES
   ============================================================ */
.container{max-width:var(--max-w);margin:0 auto;padding:0 clamp(16px,5vw,64px)}
.section{padding:clamp(72px,10vw,130px) 0}
.text-center{text-align:center}
.section-tag{display:inline-flex;align-items:center;gap:8px;padding:6px 18px;border-radius:100px;background:var(--red-100);color:var(--red-700);font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;margin-bottom:18px;border:1px solid rgba(192,57,43,.15)}
[data-theme="dark"] .section-tag{background:rgba(192,57,43,.14);color:#FF7961}
.section-tag::before{content:'';width:6px;height:6px;border-radius:50%;background:var(--gold-500)}
.section-title{font-family:'Playfair Display',serif;font-size:clamp(30px,5vw,56px);font-weight:800;color:var(--text-head);line-height:1.08;margin-bottom:14px}
.section-title em{font-style:italic;color:var(--red-700)}
.section-sub{font-size:clamp(15px,2vw,17px);color:var(--text-muted);max-width:580px;line-height:1.78}
.text-center .section-sub{margin:0 auto}

.btn{display:inline-flex;align-items:center;gap:8px;padding:13px 28px;border-radius:100px;font-size:14px;font-weight:700;letter-spacing:.04em;transition:all .3s var(--ease);position:relative;overflow:hidden;cursor:pointer;border:none}
.btn::after{content:'';position:absolute;inset:0;background:rgba(255,255,255,0);transition:.3s}
.btn:hover::after{background:rgba(255,255,255,.12)}
.btn-primary{background:var(--grad-hero);color:#fff;box-shadow:0 4px 20px rgba(192,57,43,.36)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(192,57,43,.5)}
.btn-outline{background:transparent;color:var(--text-head);border:1.5px solid var(--border)}
.btn-outline:hover{border-color:var(--red-700);color:var(--red-700);transform:translateY(-2px)}
.btn-gold{background:var(--grad-gold);color:var(--brown-900);font-weight:800;box-shadow:0 4px 20px rgba(212,160,23,.38)}
.btn-gold:hover{transform:translateY(-2px);box-shadow:0 8px 32px rgba(212,160,23,.55)}
.btn-sm{padding:9px 20px;font-size:13px}

/* AOS animations */
[data-aos]{opacity:0;transition:opacity .7s var(--ease),transform .7s var(--ease)}
[data-aos="fade-up"]{transform:translateY(40px)}
[data-aos="fade-left"]{transform:translateX(50px)}
[data-aos="fade-right"]{transform:translateX(-50px)}
[data-aos="zoom-in"]{transform:scale(.88)}
[data-aos].aos-in{opacity:1!important;transform:none!important}

/* ============================================================
   NAVBAR
   ============================================================ */
#navbar{position:fixed;top:0;left:0;right:0;z-index:900;height:var(--nav-h);transition:background .4s,box-shadow .4s,height .3s}
#navbar.scrolled{background:var(--nav-bg);backdrop-filter:blur(22px) saturate(180%);box-shadow:0 1px 0 var(--border),var(--sh-sm);height:62px}
.nav-inner{max-width:var(--max-w);margin:0 auto;height:100%;display:flex;align-items:center;justify-content:space-between;padding:0 clamp(16px,5vw,64px)}
.logo{display:flex;align-items:center;gap:10px;cursor:pointer}
.logo-icon{width:44px;height:44px;display:flex;align-items:center;justify-content:center;background:var(--grad-hero);border-radius:12px;box-shadow:0 4px 14px rgba(192,57,43,.35);transition:transform .35s var(--spring)}
.logo:hover .logo-icon{transform:rotate(-8deg) scale(1.1)}
.logo-text{display:flex;flex-direction:column;line-height:1}
.logo-name{font-family:'Playfair Display',serif;font-size:16px;font-weight:800;color:var(--text-head);transition:color .3s}
#navbar:not(.scrolled) .logo-name{color:#FFF3E0}
.logo-tagline{font-size:9px;font-weight:700;letter-spacing:.18em;text-transform:uppercase;color:var(--gold-500)}
.nav-links{display:flex;align-items:center;gap:2px}
.nav-link{padding:8px 13px;border-radius:8px;font-size:13px;font-weight:600;color:var(--text-muted);transition:all .25s;position:relative}
.nav-link::after{content:'';position:absolute;bottom:4px;left:50%;right:50%;height:2px;background:var(--gold-500);border-radius:2px;transition:all .3s}
.nav-link:hover::after,.nav-link.active::after{left:13px;right:13px}
.nav-link:hover,.nav-link.active{color:var(--red-700);background:var(--red-100)}
#navbar:not(.scrolled) .nav-link{color:rgba(255,243,224,.82)}
#navbar:not(.scrolled) .nav-link:hover{color:#fff;background:rgba(255,255,255,.12)}
.nav-actions{display:flex;align-items:center;gap:10px}
#theme-toggle{width:40px;height:40px;border-radius:10px;background:var(--red-100);color:var(--red-700);font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .3s}
#theme-toggle:hover{background:var(--red-700);color:#fff;transform:rotate(18deg)}
#navbar:not(.scrolled) #theme-toggle{background:rgba(255,255,255,.14);color:#FFF3E0}
#hamburger{display:none;flex-direction:column;gap:5px;padding:8px}
#hamburger span{display:block;width:24px;height:2px;background:var(--text-head);border-radius:2px;transition:all .3s}
#navbar:not(.scrolled) #hamburger span{background:#FFF3E0}
#hamburger.open span:nth-child(1){transform:rotate(45deg) translate(5px,5px)}
#hamburger.open span:nth-child(2){opacity:0;transform:scaleX(0)}
#hamburger.open span:nth-child(3){transform:rotate(-45deg) translate(5px,-5px)}
#mobile-nav{display:none;position:fixed;top:var(--nav-h);left:0;right:0;bottom:0;z-index:898;background:var(--bg-overlay);backdrop-filter:blur(24px);flex-direction:column;padding:28px clamp(16px,5vw,40px);gap:4px;border-top:1px solid var(--border)}
#mobile-nav.open{display:flex}
#mobile-nav a{padding:15px 18px;border-radius:12px;font-size:18px;font-weight:600;color:var(--text-head);border-bottom:1px solid var(--border);transition:all .22s}
#mobile-nav a:hover{background:var(--red-100);color:var(--red-700);padding-left:26px}

/* ============================================================
   HERO
   ============================================================ */
#hero{min-height:100vh;position:relative;display:flex;align-items:center;overflow:hidden}
/* ── THAY ẢNH NỀN HERO: sửa URL trong .hero-bg bên dưới ── */
.hero-bg{position:absolute;inset:0;z-index:0;background:linear-gradient(135deg,#2C1A0E 0%,#8B0000 30%,#C0392B 55%,#E67E22 80%,#B7860D 100%)}
.hero-bg-img{position:absolute;inset:0;z-index:0;width:100%;height:100%;object-fit:cover;object-position:center}
.hero-overlay{position:absolute;inset:0;z-index:1;background:linear-gradient(135deg,rgba(139,0,0,.78) 0%,rgba(44,26,14,.72) 100%)}
.hero-mesh{position:absolute;inset:0;z-index:1;pointer-events:none;background:radial-gradient(ellipse 60% 70% at 65% 50%,rgba(230,126,34,.15) 0%,transparent 55%)}
.hero-float{position:absolute;z-index:2;pointer-events:none;animation:heroFloat var(--dur,5s) ease-in-out infinite}
.hero-float:nth-child(1){top:18%;right:8%;font-size:44px;--dur:4.8s}
.hero-float:nth-child(2){top:60%;right:14%;font-size:36px;--dur:6.2s;animation-delay:-1.5s}
.hero-float:nth-child(3){top:30%;right:22%;font-size:28px;--dur:5.5s;animation-delay:-3s}
.hero-float:nth-child(4){top:75%;right:5%;font-size:32px;--dur:7s;animation-delay:-2s}
@keyframes heroFloat{0%,100%{transform:translateY(0) rotate(0deg)}50%{transform:translateY(-18px) rotate(5deg)}}
.hero-content{position:relative;z-index:3;max-width:var(--max-w);margin:0 auto;width:100%;padding:calc(var(--nav-h) + 40px) clamp(16px,5vw,64px) 80px;display:grid;grid-template-columns:1fr 1fr;gap:clamp(32px,6vw,80px);align-items:center;min-height:100vh}
.hero-text{display:flex;flex-direction:column}
.hero-badge{display:inline-flex;align-items:center;gap:10px;padding:9px 20px;border-radius:100px;width:fit-content;background:rgba(255,255,255,.12);backdrop-filter:blur(12px);border:1px solid rgba(255,255,255,.25);color:rgba(255,243,224,.95);font-size:12px;font-weight:700;letter-spacing:.16em;text-transform:uppercase;margin-bottom:28px;animation:fadeUp .7s .2s both}
.badge-dot{width:8px;height:8px;border-radius:50%;background:var(--gold-300);animation:dotPulse 2s infinite}
@keyframes dotPulse{0%,100%{opacity:1;transform:scale(1)}50%{opacity:.4;transform:scale(1.5)}}
.hero-title{font-family:'Playfair Display',serif;font-size:clamp(44px,7.5vw,92px);font-weight:800;line-height:1.02;color:#FFF3E0;margin-bottom:24px;animation:fadeUp .7s .35s both}
.hero-title-accent{font-style:italic;color:var(--gold-300);display:block;margin-top:4px}
.hero-desc{font-size:clamp(15px,2vw,18px);color:rgba(255,243,224,.75);line-height:1.8;max-width:520px;margin-bottom:38px;animation:fadeUp .7s .5s both}
.hero-btns{display:flex;gap:14px;flex-wrap:wrap;animation:fadeUp .7s .65s both}
.hero-stats{display:flex;gap:32px;margin-top:48px;padding-top:32px;border-top:1px solid rgba(255,255,255,.12);flex-wrap:wrap;animation:fadeUp .7s .8s both}
.hero-stat-num{font-family:'Playfair Display',serif;font-size:clamp(28px,4vw,46px);font-weight:800;color:var(--gold-300);line-height:1}
.hero-stat-label{font-size:12px;color:rgba(255,243,224,.6);font-weight:600;letter-spacing:.06em;margin-top:4px}
.hero-cards{display:grid;grid-template-columns:1fr 1fr;gap:14px;animation:fadeLeft .9s .4s both}
.hero-card{background:rgba(255,255,255,.1);backdrop-filter:blur(16px);border:1px solid rgba(255,255,255,.2);border-radius:var(--r-lg);padding:22px 18px;text-align:center;cursor:pointer;transition:all .35s}
.hero-card:hover{background:rgba(255,255,255,.2);transform:translateY(-8px);box-shadow:0 14px 42px rgba(0,0,0,.25)}
.hero-card:nth-child(2){margin-top:20px}
.hero-card:nth-child(4){margin-top:-20px}
.hero-card-icon{font-size:38px;margin-bottom:10px}
.hero-card-name{font-family:'Playfair Display',serif;font-size:15px;font-weight:700;color:#FFF3E0;margin-bottom:5px}
.hero-card-info{font-size:11px;color:var(--gold-300);font-weight:600}
.hero-scroll{position:absolute;bottom:36px;left:50%;transform:translateX(-50%);display:flex;flex-direction:column;align-items:center;gap:8px;color:rgba(255,243,224,.48);font-size:11px;letter-spacing:.16em;text-transform:uppercase;z-index:4;animation:fadeIn 1s 1.3s both}
.scroll-bar{width:1px;height:52px;background:linear-gradient(to bottom,transparent,rgba(255,243,224,.55));animation:scrollAnim 2s ease-in-out infinite}
@keyframes fadeUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:none}}
@keyframes fadeLeft{from{opacity:0;transform:translateX(40px)}to{opacity:1;transform:none}}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
@keyframes scrollAnim{0%,100%{opacity:.3}50%{opacity:1}}

/* ============================================================
   PREVIEW
   ============================================================ */
#preview{background:var(--bg);padding:clamp(48px,8vw,80px) 0;border-top:1px solid var(--border)}
.preview-heading{display:flex;align-items:center;justify-content:space-between;margin-bottom:32px;flex-wrap:wrap;gap:12px}
.preview-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:24px}
.preview-card{border-radius:var(--r-lg);overflow:hidden;position:relative;min-height:300px;display:flex;flex-direction:column;justify-content:flex-end;cursor:pointer;transition:transform .4s,box-shadow .4s}
.preview-card:hover{transform:translateY(-10px) scale(1.018);box-shadow:var(--sh-xl)}
.preview-bg{position:absolute;inset:0;background-size:cover;background-position:center;transition:transform .55s}
.preview-card:hover .preview-bg{transform:scale(1.08)}
.preview-overlay{position:absolute;inset:0;background:linear-gradient(to top,rgba(0,0,0,.88) 0%,rgba(0,0,0,.2) 55%,transparent 100%)}
.preview-body{position:relative;z-index:1;padding:26px 22px}
.preview-icon{font-size:36px;margin-bottom:10px}
.preview-name{font-family:'Playfair Display',serif;font-size:22px;font-weight:800;color:#fff;margin-bottom:7px}
.preview-desc{font-size:13px;color:rgba(255,255,255,.75);line-height:1.6;margin-bottom:16px}
.preview-arrow{width:38px;height:38px;border-radius:50%;background:var(--gold-500);color:var(--brown-900);display:inline-flex;align-items:center;justify-content:center;font-size:18px;font-weight:800;transition:all .3s var(--spring)}
.preview-card:hover .preview-arrow{transform:translateX(5px) scale(1.14)}

/* ============================================================
   ABOUT
   ============================================================ */
#about{background:var(--brown-100)}
[data-theme="dark"] #about{background:#120600}
.about-layout{display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,7vw,100px);align-items:start;margin-top:48px}
.about-visual{position:relative}
.about-img-box{aspect-ratio:3/4;border-radius:var(--r-2xl);overflow:hidden;box-shadow:var(--sh-xl);background:var(--grad-hero);display:flex;align-items:center;justify-content:center}
.about-img-box img{width:100%;height:100%;object-fit:cover;display:block}
.about-img-emoji{font-size:100px}
.about-float-card{position:absolute;bottom:-24px;right:-24px;background:var(--grad-gold);border-radius:var(--r-lg);padding:20px 24px;box-shadow:var(--sh-lg);border:4px solid var(--bg);text-align:center}
.float-big{font-family:'Playfair Display',serif;font-size:44px;font-weight:800;color:var(--brown-900);line-height:1}
.float-lbl{font-size:12px;font-weight:700;color:var(--brown-700);margin-top:4px}
.about-features{display:flex;flex-direction:column;gap:20px}
.about-feat{padding:22px;background:var(--bg-card);border-radius:var(--r-md);border:1px solid var(--border);box-shadow:var(--sh-xs);display:flex;gap:16px;align-items:flex-start;transition:all .3s}
.about-feat:hover{transform:translateX(6px);box-shadow:var(--sh-md)}
.about-feat-icon{width:50px;height:50px;border-radius:12px;flex-shrink:0;background:var(--red-100);display:flex;align-items:center;justify-content:center;font-size:24px}
.about-feat-title{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--text-head);margin-bottom:6px}
.about-feat-desc{font-size:13.5px;color:var(--text-muted);line-height:1.7}
.timeline{margin-top:56px}
.timeline-title{font-family:'Playfair Display',serif;font-size:26px;font-weight:800;color:var(--text-head);margin-bottom:32px;text-align:center}
.timeline-items{position:relative;max-width:640px;margin:0 auto;display:flex;flex-direction:column}
.timeline-items::before{content:'';position:absolute;left:21px;top:0;bottom:0;width:2px;background:linear-gradient(var(--red-700),var(--gold-500))}
.t-item{display:flex;gap:20px;align-items:flex-start;padding-bottom:32px}
.t-dot{width:44px;height:44px;border-radius:50%;flex-shrink:0;background:var(--grad-warm);display:flex;align-items:center;justify-content:center;font-size:18px;box-shadow:0 0 0 5px var(--red-100);z-index:1;transition:transform .3s var(--spring)}
[data-theme="dark"] .t-dot{box-shadow:0 0 0 5px rgba(192,57,43,.2)}
.t-item:hover .t-dot{transform:scale(1.18) rotate(10deg)}
.t-body{flex:1;padding-top:8px}
.t-year{font-size:11px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:var(--red-700);margin-bottom:4px}
.t-title{font-family:'Playfair Display',serif;font-size:17px;font-weight:700;color:var(--text-head);margin-bottom:6px}
.t-desc{font-size:13.5px;color:var(--text-muted);line-height:1.7}

/* ============================================================
   SEARCH BAR
   ============================================================ */
#search-bar{position:sticky;top:var(--nav-h);z-index:80;background:var(--bg-card);border-bottom:1px solid var(--border);padding:16px 0;box-shadow:var(--sh-sm)}
.search-inner{display:flex;gap:14px;align-items:center;flex-wrap:wrap}
.search-wrap{position:relative;flex:1;min-width:240px}
.search-ico{position:absolute;left:16px;top:50%;transform:translateY(-50%);color:var(--text-muted);pointer-events:none;font-size:17px}
#search-input{width:100%;padding:12px 16px 12px 46px;border:1.5px solid var(--border);border-radius:100px;background:var(--bg);color:var(--text-head);font-size:14px;transition:all .3s}
#search-input:focus{outline:none;border-color:var(--red-700);box-shadow:0 0 0 3px rgba(192,57,43,.1)}
#search-input::placeholder{color:var(--ink-30)}
.filter-row{display:flex;gap:8px;flex-wrap:wrap}
.filter-btn{padding:8px 18px;border-radius:100px;font-size:13px;font-weight:600;border:1.5px solid var(--border);background:transparent;color:var(--text-muted);transition:all .25s}
.filter-btn:hover{border-color:var(--red-700);color:var(--red-700)}
.filter-btn.active{background:var(--red-700);border-color:var(--red-700);color:#fff;box-shadow:0 4px 14px rgba(192,57,43,.3)}
#result-count{font-size:13px;color:var(--text-muted);white-space:nowrap;font-style:italic}
mark.hl{background:var(--gold-100);color:var(--gold-700);border-radius:3px;padding:0 2px}

/* ============================================================
   DISHES
   ============================================================ */
.dishes-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,310px),1fr));gap:28px;margin-top:48px}
.dish-card{background:var(--bg-card);border-radius:var(--r-lg);border:1px solid var(--border);box-shadow:var(--sh-xs);overflow:hidden;cursor:pointer;transition:transform .4s,box-shadow .4s;display:flex;flex-direction:column}
.dish-card:hover{transform:translateY(-10px) scale(1.012);box-shadow:var(--sh-lg)}
.dish-img{height:210px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;transition:transform .5s;flex-shrink:0}
.dish-img-photo{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;transition:transform .5s}
.dish-card:hover .dish-img-photo{transform:scale(1.06)}
.dish-card:hover .dish-img{transform:scale(1.06)}
.dish-emoji-fallback{font-size:80px;position:relative;z-index:1}
.dish-region-tag{position:absolute;top:12px;left:12px;padding:4px 12px;border-radius:100px;background:rgba(0,0,0,.55);backdrop-filter:blur(8px);color:#fff;font-size:10px;font-weight:700;letter-spacing:.1em;text-transform:uppercase;z-index:2}
.dish-fav{position:absolute;top:12px;right:12px;width:36px;height:36px;border-radius:50%;background:rgba(255,255,255,.9);backdrop-filter:blur(8px);font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .3s var(--spring);box-shadow:var(--sh-xs);z-index:2}
.dish-fav:hover{transform:scale(1.22)}
.dish-fav.liked{background:#FFF0F0}
@keyframes favPop{0%,100%{transform:scale(1)}50%{transform:scale(1.45)}}
.dish-fav.pop{animation:favPop .35s var(--spring)}
.dish-body{padding:18px 20px 16px;flex:1;display:flex;flex-direction:column}
.dish-cat{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--amber-500);margin-bottom:6px}
.dish-name{font-family:'Playfair Display',serif;font-size:20px;font-weight:800;color:var(--text-head);margin-bottom:8px;line-height:1.2}
.dish-desc{font-size:13px;color:var(--text-muted);line-height:1.65;margin-bottom:14px;flex:1;display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden}
.dish-meta{display:flex;align-items:center;justify-content:space-between;margin-bottom:14px}
.dish-stars{display:flex;gap:2px}
.star-btn{background:none;border:none;font-size:16px;color:#D1C4A0;transition:all .2s;cursor:pointer;padding:0;line-height:1}
.star-btn.on{color:var(--gold-500)}
.star-btn:hover{transform:scale(1.35)}
.dish-price{font-family:'Playfair Display',serif;font-size:18px;font-weight:800;color:var(--red-700)}
.dish-footer{padding:0 20px 18px;display:flex;gap:8px}
.skel-card{background:var(--bg-card);border-radius:var(--r-lg);border:1px solid var(--border);overflow:hidden}
.skel{background:linear-gradient(90deg,var(--border) 25%,rgba(200,150,100,.12) 50%,var(--border) 75%);background-size:200% 100%;animation:shimmer 1.7s infinite;border-radius:6px}
.skel-img{height:210px;border-radius:0}
.skel-body{padding:20px;display:flex;flex-direction:column;gap:10px}
.skel-line{height:14px}
.skel-line.w70{width:70%}
.skel-line.w50{width:50%}
@keyframes shimmer{to{background-position:-200% 0}}
.no-results{grid-column:1/-1;text-align:center;padding:80px 20px}
.no-results-icon{font-size:64px;margin-bottom:16px}
.no-results h3{font-family:'Playfair Display',serif;font-size:26px;color:var(--text-head);margin-bottom:8px}

/* ============================================================
   FEATURED CAROUSEL
   ============================================================ */
#featured{background:var(--red-100)}
[data-theme="dark"] #featured{background:#1A0500}
.carousel-outer{margin-top:48px}
.carousel-track-wrap{overflow:hidden;border-radius:var(--r-xl)}
.carousel-track{display:flex;transition:transform .55s var(--ease)}
.carousel-slide{min-width:100%;display:grid;grid-template-columns:1fr 1fr;border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-xl)}
.slide-visual{min-height:420px;display:flex;align-items:center;justify-content:center;font-size:130px;position:relative;overflow:hidden}
.slide-visual-bg{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55}
.slide-visual-overlay{position:absolute;inset:0;background:rgba(0,0,0,.25)}
.slide-emoji{filter:drop-shadow(0 12px 36px rgba(0,0,0,.35));animation:slFloat 3s ease-in-out infinite;position:relative;z-index:1}
@keyframes slFloat{0%,100%{transform:translateY(0)}50%{transform:translateY(-14px)}}
.slide-body{background:var(--bg-card);padding:clamp(28px,5vw,52px);display:flex;flex-direction:column;justify-content:center}
.slide-tag{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--amber-500);margin-bottom:12px}
.slide-name{font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,44px);font-weight:800;color:var(--text-head);line-height:1.12;margin-bottom:14px}
.slide-desc{font-size:15px;color:var(--text-muted);line-height:1.78;margin-bottom:28px}
.slide-metas{display:flex;gap:24px;margin-bottom:28px;flex-wrap:wrap}
.slide-meta-item{display:flex;flex-direction:column;gap:3px}
.slide-meta-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.12em;color:var(--text-muted)}
.slide-meta-val{font-size:15px;font-weight:700;color:var(--text-head)}
.carousel-nav{display:flex;align-items:center;gap:16px;margin-top:24px}
.carousel-arrow{width:44px;height:44px;border-radius:50%;border:1.5px solid var(--border);background:var(--bg-card);color:var(--text-head);font-size:18px;display:flex;align-items:center;justify-content:center;transition:all .3s;flex-shrink:0}
.carousel-arrow:hover{background:var(--red-700);border-color:var(--red-700);color:#fff;transform:scale(1.1)}
.carousel-dots{display:flex;gap:8px}
.carousel-dot{width:8px;height:8px;border-radius:100px;background:var(--border);transition:all .35s}
.carousel-dot.on{width:28px;background:var(--red-700)}

/* ============================================================
   VIDEOS
   ============================================================ */
.videos-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(min(100%,340px),1fr));gap:24px;margin-top:48px}
.video-card{background:var(--bg-card);border-radius:var(--r-lg);border:1px solid var(--border);overflow:hidden;transition:all .35s}
.video-card:hover{transform:translateY(-6px);box-shadow:var(--sh-md)}
.video-thumb{position:relative;aspect-ratio:16/9;overflow:hidden;background:var(--brown-900);display:flex;align-items:center;justify-content:center}
.video-thumb-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.7;transition:opacity .3s,transform .4s}
.video-card:hover .video-thumb-img{opacity:.9;transform:scale(1.06)}
.video-thumb-emoji{font-size:56px;position:relative;z-index:1;transition:transform .4s}
.video-card:hover .video-thumb-emoji{transform:scale(1.1)}
.video-yt-overlay{position:absolute;inset:0;z-index:2;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:12px;background:rgba(0,0,0,.3);transition:background .3s}
.video-card:hover .video-yt-overlay{background:rgba(0,0,0,.45)}
.video-yt-btn{display:inline-flex;align-items:center;gap:9px;padding:12px 22px;border-radius:100px;background:#FF0000;color:#fff;font-size:14px;font-weight:700;box-shadow:0 4px 20px rgba(255,0,0,.45);transition:all .3s var(--spring);text-decoration:none}
.video-yt-btn:hover{transform:scale(1.08) translateY(-2px);box-shadow:0 8px 30px rgba(255,0,0,.6);background:#cc0000}
.video-body{padding:18px 20px 20px}
.video-region{font-size:11px;font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--amber-500);margin-bottom:6px}
.video-name{font-family:'Playfair Display',serif;font-size:18px;font-weight:700;color:var(--text-head);margin-bottom:8px}
.video-desc{font-size:13px;color:var(--text-muted);line-height:1.65}

/* ============================================================
   CONTACT
   ============================================================ */
#contact{background:var(--brown-100)}
[data-theme="dark"] #contact{background:#120600}
.contact-grid{display:grid;grid-template-columns:1fr 1fr;gap:clamp(40px,6vw,80px)}
.contact-info{display:flex;flex-direction:column;gap:24px}
.c-info-card{display:flex;gap:16px;align-items:flex-start;padding:22px;background:var(--bg-card);border-radius:var(--r-md);border:1px solid var(--border);box-shadow:var(--sh-xs);transition:all .3s}
.c-info-card:hover{transform:translateX(6px);box-shadow:var(--sh-md)}
.c-icon{width:50px;height:50px;border-radius:12px;flex-shrink:0;background:var(--red-100);display:flex;align-items:center;justify-content:center;font-size:22px}
.c-lbl{font-size:11px;text-transform:uppercase;letter-spacing:.12em;color:var(--text-muted);margin-bottom:4px}
.c-val{font-weight:700;color:var(--text-head);font-size:15px}
.c-val a{color:var(--red-700);text-decoration:none}
.contact-form{background:var(--bg-card);border-radius:var(--r-2xl);padding:clamp(28px,4vw,48px);border:1px solid var(--border);box-shadow:var(--sh-sm)}
.form-row2{display:grid;grid-template-columns:1fr 1fr;gap:16px}
.fg{display:flex;flex-direction:column;gap:7px;margin-bottom:18px}
.fg label{font-size:13px;font-weight:700;color:var(--text-head)}
.fg input,.fg textarea,.fg select{width:100%;padding:12px 16px;border:1.5px solid var(--border);border-radius:var(--r-sm);background:var(--bg);color:var(--text-head);font-size:14px;transition:all .3s;resize:none}
.fg input:focus,.fg textarea:focus,.fg select:focus{outline:none;border-color:var(--red-700);box-shadow:0 0 0 3px rgba(192,57,43,.1)}
.fg textarea{height:120px}
.form-status{margin-top:14px;padding:12px 16px;border-radius:var(--r-sm);font-size:14px;display:none}
.form-status.ok{background:#ECFDF5;color:#065F46;border:1px solid #A7F3D0;display:block}
.form-status.err{background:#FEF2F2;color:#991B1B;border:1px solid #FCA5A5;display:block}
/* Google Maps section */
.map-section{margin-top:56px}
.map-section-title{font-family:'Playfair Display',serif;font-size:22px;font-weight:800;color:var(--text-head);margin-bottom:16px;display:flex;align-items:center;gap:10px}
.map-wrap{border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-md);border:1px solid var(--border)}
.map-wrap iframe{display:block;width:100%;height:380px;border:0}

/* ============================================================
   MODAL
   ============================================================ */
#modal-overlay{position:fixed;inset:0;z-index:2000;display:flex;align-items:center;justify-content:center;padding:20px;opacity:0;visibility:hidden;transition:opacity .4s,visibility .4s}
#modal-overlay.open{opacity:1;visibility:visible}
.modal-backdrop{position:absolute;inset:0;background:rgba(0,0,0,.78);backdrop-filter:blur(8px);cursor:pointer}
.modal-box{position:relative;z-index:1;background:var(--bg-card);border-radius:var(--r-2xl);width:100%;max-width:940px;max-height:92vh;overflow-y:auto;transform:scale(.9) translateY(24px);transition:transform .42s var(--spring);box-shadow:var(--sh-xl);border:1px solid var(--border)}
#modal-overlay.open .modal-box{transform:scale(1) translateY(0)}
.modal-hero{height:300px;position:relative;display:flex;align-items:center;justify-content:center;overflow:hidden;flex-shrink:0}
.modal-hero-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.modal-hero-dim{position:absolute;inset:0;background:rgba(0,0,0,.3)}
.modal-hero-emoji{font-size:120px;filter:drop-shadow(0 12px 32px rgba(0,0,0,.3));position:relative;z-index:1}
.modal-close{position:absolute;top:16px;right:16px;width:44px;height:44px;border-radius:50%;background:rgba(255,255,255,.9);backdrop-filter:blur(8px);font-size:22px;display:flex;align-items:center;justify-content:center;transition:all .3s var(--spring);color:var(--ink);z-index:2}
.modal-close:hover{background:#fff;transform:rotate(90deg) scale(1.1)}
.modal-body{padding:clamp(22px,4vw,40px)}
.modal-region{font-size:11px;font-weight:700;letter-spacing:.14em;text-transform:uppercase;color:var(--amber-500);margin-bottom:8px}
.modal-name{font-family:'Playfair Display',serif;font-size:clamp(26px,4vw,40px);font-weight:800;color:var(--text-head);margin-bottom:16px}
.modal-info-row{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:28px}
.modal-info-cell{background:var(--red-100);border-radius:var(--r-md);padding:16px;text-align:center}
[data-theme="dark"] .modal-info-cell{background:rgba(192,57,43,.12)}
.cell-icon{font-size:22px;margin-bottom:6px}
.cell-lbl{font-size:10px;text-transform:uppercase;letter-spacing:.1em;color:var(--text-muted);margin-bottom:4px}
.cell-val{font-weight:700;color:var(--text-head);font-size:13px}
.modal-sect{margin-bottom:24px}
.modal-sect-title{font-family:'Playfair Display',serif;font-size:18px;font-weight:800;color:var(--text-head);margin-bottom:10px;display:flex;align-items:center;gap:8px}
.modal-sect-title::before{content:'';width:4px;height:18px;border-radius:2px;background:var(--red-700);display:block}
.modal-desc{font-size:15px;color:var(--text-body);line-height:1.82}
.modal-tags{display:flex;gap:8px;flex-wrap:wrap;margin-top:8px}
.mtag{padding:5px 14px;border-radius:100px;font-size:12px;font-weight:600;background:var(--red-100);color:var(--red-700)}
.mtag.gold{background:var(--gold-100);color:var(--gold-700)}
[data-theme="dark"] .mtag{background:rgba(192,57,43,.14);color:#FF7961}
[data-theme="dark"] .mtag.gold{background:rgba(212,160,23,.14);color:var(--gold-300)}
.mc-wrap{position:relative;overflow:hidden;border-radius:var(--r-lg)}
.mc-track{display:flex;transition:transform .5s var(--ease)}
.mc-slide{min-width:100%;height:220px;display:flex;align-items:center;justify-content:center;font-size:90px;border-radius:var(--r-lg);overflow:hidden;position:relative}
.mc-slide-img{position:absolute;inset:0;width:100%;height:100%;object-fit:cover}
.mc-slide-emoji{position:relative;z-index:1;font-size:90px}
.mc-nav{display:flex;gap:6px;justify-content:center;margin-top:10px}
.mc-dot{width:8px;height:8px;border-radius:100px;background:var(--border);transition:all .3s;cursor:pointer}
.mc-dot.on{width:26px;background:var(--red-700)}
.mc-btn{position:absolute;top:50%;transform:translateY(-50%);width:38px;height:38px;border-radius:50%;background:rgba(255,255,255,.88);backdrop-filter:blur(6px);color:var(--ink);font-size:17px;display:flex;align-items:center;justify-content:center;transition:all .3s;box-shadow:var(--sh-sm)}
.mc-btn:hover{background:#fff;transform:translateY(-50%) scale(1.1)}
.mc-btn.p{left:10px}
.mc-btn.n{right:10px}
.modal-video-box{border-radius:var(--r-md);overflow:hidden;background:var(--brown-900);position:relative;aspect-ratio:16/9;display:flex;align-items:center;justify-content:center;cursor:pointer}
.modal-video-thumb{position:absolute;inset:0;width:100%;height:100%;object-fit:cover;opacity:.55}
.modal-video-center{position:relative;z-index:1;display:flex;flex-direction:column;align-items:center;gap:14px}
.modal-yt-play{width:70px;height:70px;border-radius:50%;background:#FF0000;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 28px rgba(255,0,0,.55);transition:all .3s var(--spring);text-decoration:none}
.modal-yt-play:hover{transform:scale(1.14);box-shadow:0 10px 38px rgba(255,0,0,.75)}
.modal-yt-open{display:inline-flex;align-items:center;gap:8px;padding:10px 20px;border-radius:100px;background:rgba(255,255,255,.9);color:#111;font-size:13px;font-weight:700;text-decoration:none;transition:all .3s}
.modal-yt-open:hover{background:#fff;transform:translateY(-2px)}
.modal-footer-btns{display:flex;gap:12px;flex-wrap:wrap;margin-top:28px;padding-top:24px;border-top:1px solid var(--border)}

/* ============================================================
   FOOTER
   ============================================================ */
footer{background:var(--brown-900);color:rgba(255,243,224,.8);padding:clamp(48px,8vw,80px) 0 0}
.footer-grid{display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:clamp(24px,4vw,56px);padding-bottom:clamp(40px,6vw,60px);border-bottom:1px solid rgba(255,243,224,.08)}
.ft-logo{display:flex;align-items:center;gap:10px;margin-bottom:16px}
.ft-logo-icon{width:42px;height:42px;border-radius:10px;background:var(--grad-warm);display:flex;align-items:center;justify-content:center;font-size:20px}
.ft-logo-name{font-family:'Playfair Display',serif;font-size:17px;font-weight:800;color:#FFF3E0}
.ft-desc{font-size:14px;line-height:1.75;color:rgba(255,243,224,.6);margin-bottom:24px}
.ft-socials{display:flex;gap:10px}
.soc-btn{width:38px;height:38px;border-radius:9px;background:rgba(255,243,224,.08);border:1px solid rgba(255,243,224,.12);color:rgba(255,243,224,.75);font-size:16px;display:flex;align-items:center;justify-content:center;transition:all .3s;text-decoration:none}
.soc-btn:hover{background:var(--red-700);border-color:var(--red-700);color:#fff;transform:translateY(-3px)}
.ft-col-title{font-size:12px;font-weight:800;letter-spacing:.14em;text-transform:uppercase;color:#FFF3E0;margin-bottom:16px}
.ft-links{display:flex;flex-direction:column;gap:10px}
.ft-links a{font-size:14px;color:rgba(255,243,224,.6);transition:all .25s}
.ft-links a:hover{color:#FFF3E0;padding-left:6px}
.footer-bottom{display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:12px;padding:20px 0;font-size:13px;color:rgba(255,243,224,.38)}
.footer-bottom a{color:var(--gold-300)}

/* ============================================================
   BACK-TOP + TOAST
   ============================================================ */
#back-top{position:fixed;bottom:28px;right:28px;z-index:500;width:50px;height:50px;border-radius:14px;background:var(--grad-warm);color:#fff;font-size:22px;display:flex;align-items:center;justify-content:center;box-shadow:0 6px 24px rgba(192,57,43,.42);transform:translateY(80px);opacity:0;transition:all .4s var(--spring)}
#back-top.show{transform:translateY(0);opacity:1}
#back-top:hover{transform:translateY(-5px) scale(1.08)}
#toast{position:fixed;bottom:28px;left:50%;transform:translateX(-50%) translateY(100px);z-index:3000;background:var(--ink);color:#FFF3E0;padding:13px 26px;border-radius:100px;font-size:14px;font-weight:600;box-shadow:0 8px 32px rgba(0,0,0,.3);opacity:0;pointer-events:none;white-space:nowrap;display:flex;align-items:center;gap:9px;transition:transform .4s var(--spring),opacity .4s}
#toast.show{transform:translateX(-50%) translateY(0);opacity:1}

/* ============================================================
   RESPONSIVE
   ============================================================ */
@media(max-width:1080px){
  .hero-content{grid-template-columns:1fr;min-height:auto;padding-bottom:60px}
  .hero-cards{display:none}
  .about-layout{grid-template-columns:1fr}
  .about-visual{display:none}
  .preview-grid{grid-template-columns:1fr}
  .carousel-slide{grid-template-columns:1fr}
  .slide-visual{min-height:260px}
  .modal-info-row{grid-template-columns:1fr 1fr}
  .footer-grid{grid-template-columns:1fr 1fr}
  .contact-grid{grid-template-columns:1fr}
}
@media(max-width:768px){
  .nav-links,.nav-actions .btn{display:none}
  #hamburger{display:flex}
  .form-row2{grid-template-columns:1fr}
  .footer-grid{grid-template-columns:1fr}
  .footer-bottom{flex-direction:column;text-align:center}
}
@media(max-width:520px){
  .hero-btns{flex-direction:column}
  .hero-btns .btn{width:100%;justify-content:center;max-width:280px}
  .modal-info-row{grid-template-columns:1fr 1fr}
  .preview-grid{grid-template-columns:1fr}
}
</style>
