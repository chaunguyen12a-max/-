  STATE.modalId = null;
}

function mcMove(dir) {
  const dish = DISHES.find(d => d.id === STATE.modalId); if(!dish) return;
  STATE.mcIdx = (STATE.mcIdx + dir + dish.slides.length) % dish.slides.length;
  updateMC();
}
function mcGo(idx) { STATE.mcIdx = idx; updateMC(); }
function updateMC() {
  const t = $('mc-track'); if(t) t.style.transform = `translateX(-${STATE.mcIdx * 100}%)`;
  $$('#mc-dots .mc-dot').forEach((d, i) => d.classList.toggle('on', i === STATE.mcIdx));
}

/* ============================================================
   CAROUSEL
   ============================================================ */
function goSlide(idx) {
  STATE.slideIdx = (idx + FEATURED.length) % FEATURED.length;
  const t = $('carousel-track'); if(t) t.style.transform = `translateX(-${STATE.slideIdx * 100}%)`;
  $$('.carousel-dot').forEach((d, i) => d.classList.toggle('on', i === STATE.slideIdx));
}
function initCarousel() {
  const p = $('car-prev'), n = $('car-next');
  if(p) p.addEventListener('click', ()=> goSlide(STATE.slideIdx - 1));
  if(n) n.addEventListener('click', ()=> goSlide(STATE.slideIdx + 1));
  setInterval(()=> goSlide(STATE.slideIdx + 1), 5500);
}

/* ============================================================
   SEARCH + FILTER
   ============================================================ */
function initSearch() {
  const inp = $('search-input'); if(!inp) return;
  let t;
  inp.addEventListener('input', ()=>{
    clearTimeout(t);
    t = setTimeout(()=>{ STATE.query = inp.value || ''; renderDishes(); }, 280);
  });
}
function initFilters() {
  const row = $('filter-row'); if(!row) return;
  row.addEventListener('click', e=>{
    const btn = e.target.closest('.filter-btn'); if(!btn) return;
    STATE.filter = btn.dataset.region || 'all';
    $$('.filter-btn').forEach(b => b.classList.toggle('active', b === btn));
    renderDishes();
  });
}

/* ============================================================
   FAVORITES + RATINGS + SHARE
   ============================================================ */
function toggleFav(dishId, btn, fromModal) {
  const idx = STATE.favorites.indexOf(dishId);
  if(idx >= 0) { STATE.favorites.splice(idx, 1); toast('Đã xóa khỏi yêu thích', '💔'); }
  else          { STATE.favorites.push(dishId);   toast('Đã thêm vào yêu thích!', '❤️'); }
  saveFavs();
  renderDishes();
  if(fromModal) {
    const fb = $('modal-fav-btn');
    if(fb) fb.textContent = STATE.favorites.includes(dishId) ? '❤️ Đã yêu thích' : '🤍 Yêu thích';
  }
}
function rateItem(e, dishId, star) {
  if(e) e.stopPropagation();
  STATE.ratings[dishId] = star;
  saveRatings();
  toast('Đánh giá ' + star + ' sao!', '⭐');
  renderDishes();
}
function shareItem(name) {
  try {
    navigator.clipboard.writeText(location.href + ' — ' + name)
      .then(()=> toast('Đã sao chép link!', '🔗'))
      .catch(()=> toast('Chia sẻ: ' + name, '🔗'));
  } catch(e) {
    toast('Chia sẻ: ' + name, '🔗');
  }
}

/* ============================================================
   CONTACT FORM
   ============================================================ */
function initContact() {
  const form = $('contact-form'); if(!form) return;
  form.addEventListener('submit', e=>{
    e.preventDefault();
    const name  = ($('cf-name')    || {}).value || '';
    const email = ($('cf-email')   || {}).value || '';
    const msg   = ($('cf-message') || {}).value || '';
    const st    = $('form-status');
    if(st) { st.className = 'form-status'; st.textContent = ''; }
    if(!name.trim() || !email.trim() || !msg.trim()) {
      if(st) { st.className = 'form-status err'; st.textContent = '⚠️ Vui lòng điền đầy đủ thông tin.'; }
      return;
    }
    if(!/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email.trim())) {
      if(st) { st.className = 'form-status err'; st.textContent = '⚠️ Email không hợp lệ.'; }
      return;
    }
    const sbtn = form.querySelector('[type="submit"]');
    if(sbtn) { sbtn.disabled = true; sbtn.textContent = 'Đang gửi...'; }
    setTimeout(()=>{
      if(st) { st.className = 'form-status ok'; st.textContent = '✅ Cảm ơn bạn! Chúng tôi sẽ phản hồi trong 24 giờ.'; }
      form.reset();
      if(sbtn) { sbtn.disabled = false; sbtn.textContent = 'Gửi Liên Hệ →'; }
      toast('Liên hệ thành công!', '📬');
    }, 1300);
  });
}

/* ============================================================
   COUNTERS
   ============================================================ */
function initCounters() {
  if(!('IntersectionObserver' in window)) return;
  const obs = new IntersectionObserver(entries=>{
    entries.forEach(en=>{
      if(!en.isIntersecting) return;
      const el = en.target;
      const target = +el.dataset.count || 0;
      const suf = el.dataset.suffix || '';
      let cur = 0;
      const step = target / 65;
      const tmr = setInterval(()=>{
        cur = Math.min(cur + step, target);
        el.textContent = Math.floor(cur).toLocaleString('vi-VN') + suf;
        if(cur >= target) clearInterval(tmr);
      }, 18);
      obs.unobserve(el);
    });
  }, { threshold: 0.5 });
  $$('[data-count]').forEach(el => obs.observe(el));
}

/* ============================================================
   GLOBAL (inline onclick handlers)
   ============================================================ */
window.openModal       = openModal;
window.closeModal      = closeModal;
window.mcMove          = mcMove;
window.mcGo            = mcGo;
window.goSlide         = goSlide;
window.toggleFav       = toggleFav;
window.rateItem        = rateItem;
window.shareItem       = shareItem;
window.toggleTheme     = toggleTheme;
window.filterAndScroll = filterAndScroll;
window.navScrollTo     = navScrollTo;  // ← dùng trong onclick HTML
window.closeMobNav     = function() {
  const ham = $('hamburger'), mob = $('mobile-nav');
  if(ham) ham.classList.remove('open');
  if(mob) mob.classList.remove('open');
  document.body.style.overflow = '';
  STATE.navOpen = false;
};

/* ============================================================
   INIT
   ============================================================ */
document.addEventListener('DOMContentLoaded', ()=>{
  applyTheme();
  initNavbar();
  initSearch();
  initFilters();
  initCounters();
  initContact();

  // Theme toggle
  const themeBtn = $('theme-toggle');
  if(themeBtn) themeBtn.addEventListener('click', toggleTheme);

  // Back to top — dùng native window.scrollTo (không bị ghi đè)
  const backTop = $('back-top');
  if(backTop) backTop.addEventListener('click', ()=> window.scrollTo({ top: 0, behavior: 'smooth' }));

  // Modal
  const backdrop = $('modal-backdrop');
  if(backdrop) backdrop.addEventListener('click', closeModal);
  document.addEventListener('keydown', e=>{
    if(e.key === 'Escape' && STATE.modalId) closeModal();
  });

  // Render skeleton trước, sau đó render thật
  renderSkeletons(6);
  setTimeout(()=>{
    renderDishes();
    renderCarousel();
    renderVideos();
    initCarousel();
    initReveal();
  }, 150);
});
</script>
