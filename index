/* ── navScrollTo: cuộn đến hash (KHÔNG ghi đè window.scrollTo) ── */
function navScrollTo(hash) {
  if(!hash || typeof hash !== 'string') return;
  const el = document.querySelector(hash);
  if(!el) return;
  const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--nav-h')) || 74;
  window.scrollTo({ top: el.offsetTop - navH, behavior: 'smooth' });
}

function filterAndScroll(region) {
  STATE.filter = region;
  $$('.filter-btn').forEach(b => b.classList.toggle('active', b.dataset.region === region));
  renderDishes();
  const el = $('dishes'); if(!el) return;
  const navH = parseInt(getComputedStyle(document.documentElement).getPropertyValue('--nav-h')) || 74;
  window.scrollTo({ top: el.offsetTop - navH, behavior: 'smooth' });
}

